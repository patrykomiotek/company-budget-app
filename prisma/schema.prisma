generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions      Session[]
  accounts      Account[]
  transactions  Transaction[]
  invoiceFiles  InvoiceFile[]
  merchants     Merchant[]
  employees     Employee[]
  products      Product[]
  customers     Customer[]
  projects      Project[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verifications")
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  FORECAST_INCOME
  FORECAST_EXPENSE
}

enum Currency {
  PLN
  EUR
  USD
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Category {
  id        Int          @id @default(autoincrement())
  publicId  String       @unique @default(uuid()) @map("public_id") @db.Uuid
  name      String
  type      CategoryType
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  subcategories Subcategory[]

  @@unique([name, type])
  @@map("categories")
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  publicId   String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name       String
  sortOrder  Int      @default(0) @map("sort_order")
  categoryId Int      @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([name, categoryId])
  @@map("subcategories")
}

model Company {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions Transaction[]
  merchants    Merchant[]
  employees    Employee[]

  @@map("companies")
}

model Merchant {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name      String
  nip       String?
  logoUrl   String?  @map("logo_url")
  userId    String   @map("user_id")
  companyId Int?     @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id])
  transactions Transaction[]

  @@unique([name, userId])
  @@map("merchants")
}

model Transaction {
  id                   Int             @id @default(autoincrement())
  publicId             String          @unique @default(uuid()) @map("public_id") @db.Uuid
  type                 TransactionType @default(EXPENSE)
  amount               Decimal         @db.Decimal(10, 2)
  currency             Currency        @default(PLN)
  exchangeRate         Decimal?        @map("exchange_rate") @db.Decimal(10, 4)
  date                 DateTime        @db.Date
  description          String?
  invoiceNumber        String?         @map("invoice_number")
  invoiceDueDate       DateTime?       @map("invoice_due_date") @db.Date
  fakturowniaInvoiceId Int?            @unique @map("fakturownia_invoice_id")
  merchantId           Int?            @map("merchant_id")
  subcategoryId        Int             @map("subcategory_id")
  companyId            Int?            @map("company_id")
  employeeId           Int?            @map("employee_id")
  customerId           Int?            @map("customer_id")
  projectId            Int?            @map("project_id")
  userId               String          @map("user_id")
  invoiceFileId        Int?            @map("receipt_id")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  merchant    Merchant?             @relation(fields: [merchantId], references: [id])
  subcategory Subcategory           @relation(fields: [subcategoryId], references: [id])
  company     Company?              @relation(fields: [companyId], references: [id])
  employee    Employee?             @relation(fields: [employeeId], references: [id])
  customer    Customer?             @relation(fields: [customerId], references: [id])
  project     Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceFile InvoiceFile?          @relation(fields: [invoiceFileId], references: [id])
  lineItems   TransactionLineItem[]

  @@index([userId, date])
  @@index([subcategoryId])
  @@index([merchantId])
  @@index([companyId])
  @@index([employeeId])
  @@index([customerId])
  @@index([projectId])
  @@index([type])
  @@map("transactions")
}

model Employee {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name      String
  companyId Int      @map("company_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([name, companyId])
  @@map("employees")
}

model Customer {
  id                  Int      @id @default(autoincrement())
  publicId            String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name                String
  displayName         String?  @map("display_name")
  nip                 String?
  street              String?
  postalCode          String?  @map("postal_code")
  city                String?
  email               String?
  phone               String?
  notes               String?
  fakturowniaClientId Int?     @unique @map("fakturownia_client_id")
  userId              String   @map("user_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  projects     Project[]

  @@unique([name, userId])
  @@map("customers")
}

model Project {
  id         Int           @id @default(autoincrement())
  publicId   String        @unique @default(uuid()) @map("public_id") @db.Uuid
  name       String
  status     ProjectStatus @default(ACTIVE)
  customerId Int?          @map("customer_id")
  userId     String        @map("user_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  customer     Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  lineItems    TransactionLineItem[]

  @@unique([name, userId])
  @@map("projects")
}

model Product {
  id                   Int         @id @default(autoincrement())
  publicId             String      @unique @default(uuid()) @map("public_id") @db.Uuid
  name                 String
  type                 ProductType @default(SERVICE)
  fakturowniaProductId Int?        @unique @map("fakturownia_product_id")
  userId               String      @map("user_id")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems TransactionLineItem[]

  @@unique([name, userId])
  @@map("products")
}

model TransactionLineItem {
  id            Int      @id @default(autoincrement())
  publicId      String   @unique @default(uuid()) @map("public_id") @db.Uuid
  name          String
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @map("unit_price") @db.Decimal(10, 2)
  vatRate       Decimal  @map("vat_rate") @db.Decimal(5, 2)
  netAmount     Decimal  @map("net_amount") @db.Decimal(10, 2)
  grossAmount   Decimal  @map("gross_amount") @db.Decimal(10, 2)
  transactionId Int      @map("transaction_id")
  productId     Int?     @map("product_id")
  projectId     Int?     @map("project_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([projectId])
  @@map("transaction_line_items")
}

model InvoiceFile {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid()) @map("public_id") @db.Uuid
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  mimeType  String   @map("mime_type")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("receipts")
}
